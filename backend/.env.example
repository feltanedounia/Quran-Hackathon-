# Anthropic API key for AI-powered tafsir feedback and nudges
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT secret for token signing (change in production!)
SECRET_KEY=your_secret_key_for_jwt_here

# Frontend URL for CORS (set to your Vercel deployment URL)
FRONTEND_URL=https://your-vercel-app.vercel.app

# Database URL (optional; uses SQLite locally if not set, PostgreSQL on Render)
# Set by Render automatically, or provide your own PostgreSQL connection string:
# DATABASE_URL=postgresql://user:password@localhost:5432/quran_db
